@model PluginSettingViewModel
@{
    Layout = "_Layout";
    ViewData.SetActivePage(PluginNavPages.Settings, "Plugin settings");
}
<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0">
        @ViewData["Title"]
        @if (Model.IsPluginPrimaryOwner)
        {
            <span class="badge bg-success fs-6 px-2 py-1 align-middle" style="font-size: 0.75rem;">Owner</span>
        }
    </h2>
    <div class="d-flex gap-3 mt-3 mt-sm-0">
        <button type="submit" form="plugin-setting-form" class="btn btn-success">Update</button>
    </div>
</div>

<div class="row">
    <div class="col-xl-8 col-xxl-constrain">
        <form id="plugin-setting-form" asp-action="Settings" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group d-flex align-items-center">
                <input asp-for="RequireGPGSignatureForRelease" type="checkbox" class="btcpay-toggle me-3" disabled="@(!Model.IsPluginPrimaryOwner)" />
                <label asp-for="RequireGPGSignatureForRelease" class="form-check-label"></label>
                @if (!Model.IsPluginPrimaryOwner)
                {
                    <input type="hidden" asp-for="RequireGPGSignatureForRelease" />
                }
            </div>

            @if (Model.IsPluginPrimaryOwner)
            {
                <div class="form-group">
                    <label asp-for="PluginTitle" class="form-label" data-required></label>
                    <input asp-for="PluginTitle" class="form-control" placeholder="My Awesome Plugin" required />
                    <span asp-validation-for="PluginTitle" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Description" class="form-label" data-required></label>
                    <textarea asp-for="Description" class="form-control" rows="5" placeholder="Plugin description..." required></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            }
            <div class="form-group">
                <label asp-for="GitRepository" class="form-label" data-required></label>
                <input asp-for="GitRepository" class="form-control" placeholder="https://github.com/Kukks/btcpayserver" required />
                <span asp-validation-for="GitRepository" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Documentation" class="form-label"></label>
                <input asp-for="Documentation" class="form-control" placeholder="https://docs.btcpayserver.org/PodServer/" />
                <span asp-validation-for="Documentation" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="VideoUrl" class="form-label"></label>
                <input asp-for="VideoUrl" class="form-control" placeholder="https://www.youtube.com/watch?v=..." />
                <span asp-validation-for="VideoUrl" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="GitRef" class="form-label"></label>
                <input asp-for="GitRef" class="form-control" placeholder="plugins/collection" />
                <span asp-validation-for="GitRef" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PluginDirectory" class="form-label"></label>
                <input asp-for="PluginDirectory" class="form-control" placeholder="Plugins/BTCPayServer.Plugins.RockstarStylist" />
                <span asp-validation-for="PluginDirectory" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BuildConfig" class="form-label"></label>
                <input asp-for="BuildConfig" class="form-control" placeholder="Release" />
                <span asp-validation-for="BuildConfig" class="text-danger"></span>
            </div>
            <div class="form-group">
                <div class="d-flex align-items-center justify-content-between gap-2">
                    <label asp-for="LogoUrl" class="form-label"></label>
                    @if (!string.IsNullOrEmpty(Model.LogoUrl))
                    {
                        <button type="submit" class="btn btn-link p-0 text-danger" name="removeLogoFile" value="true">
                            <vc:icon symbol="cross" />
                            Remove
                        </button>
                    }
                </div>
                <div class="d-flex align-items-center gap-3">
                    <input asp-for="Logo" type="file" class="form-control flex-grow" accept="image/*">
                    @if (!string.IsNullOrEmpty(Model.LogoUrl))
                    {
                        <img src="@Model.LogoUrl" alt="Logo" style="height:2.1rem;max-width:10.5rem;" />
                    }
                </div>
                <span asp-validation-for="LogoUrl" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Images" class="form-label"></label>
                <input asp-for="Images" id="settings-images-input" type="file" class="form-control" accept="image/*" multiple>
                <span asp-validation-for="Images" class="text-danger"></span>
                <div id="settings-images-limit-error" class="text-danger small mt-1 d-none"></div>
                <input type="hidden" name="ImagesUrlSubmitted" value="true" />
                <div id="images-order-list" class="d-flex gap-3 mt-2 images-order-list">
                    @if (Model.ImagesUrl is { Count: > 0 })
                    {
                        var images = Model.ImagesUrl.Where(s => !string.IsNullOrWhiteSpace(s)).ToList();
                        @for (var i = 0; i < images.Count; i++)
                        {
                            <div class="image-item border rounded p-2" data-image-item>
                                @{ var imageUrl = images[i]; }
                                <input type="hidden" name="ImagesOrder" value="existing" data-order-input />
                                <input type="hidden" name="ImagesUrl" value="@imageUrl" data-existing-input />
                                <img src="@imageUrl" alt="Image" class="image-preview" />
                                <div class="image-controls">
                                    <button type="button" class="image-control-btn image-drag-handle" data-drag-handle aria-label="Drag to reorder" title="Drag to reorder">
                                        <i class="fa fa-bars" aria-hidden="true"></i>
                                    </button>
                                    <div class="image-move-controls">
                                        <button type="button" class="image-control-btn" data-move="left" aria-label="Move image left" title="Move left">
                                            <i class="fa fa-chevron-left" aria-hidden="true"></i>
                                        </button>
                                        <button type="button" class="image-control-btn" data-move="right" aria-label="Move image right" title="Move right">
                                            <i class="fa fa-chevron-right" aria-hidden="true"></i>
                                        </button>
                                    </div>
                                    <button type="button" class="image-control-btn image-remove-btn" data-remove-image aria-label="Remove image" title="Remove">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </form>
    </div>
</div>

@section FooterScripts {
    <script>
        (() => {
            const list = document.getElementById('images-order-list');
            const input = document.getElementById('settings-images-input');
            const limitError = document.getElementById('settings-images-limit-error');
            const maxImages = 10;
            let newImageIndex = 0;
            const newImages = new Map();

            const setLimitMessage = (message) => {
                if (!limitError)
                    return;

                if (message) {
                    limitError.textContent = message;
                    limitError.classList.remove('d-none');
                }
                else {
                    limitError.textContent = '';
                    limitError.classList.add('d-none');
                }
            };

            if (input) {
                input.addEventListener('change', () => {
                    if (!list)
                        return;

                    const selectedFiles = Array.from(input.files || []);
                    const currentCount = list.querySelectorAll('[data-image-item]').length;
                    const remaining = Math.max(maxImages - currentCount, 0);
                    const acceptedFiles = selectedFiles.slice(0, remaining);
                    const droppedCount = selectedFiles.length - acceptedFiles.length;

                    for (let i = acceptedFiles.length - 1; i >= 0; i--) {
                        const file = acceptedFiles[i];
                        const imageId = `new-${newImageIndex++}`;
                        const previewUrl = URL.createObjectURL(file);
                        newImages.set(imageId, { file, previewUrl });

                        const card = document.createElement('div');
                        card.className = 'image-item border rounded p-2';
                        card.setAttribute('data-image-item', 'true');
                        card.setAttribute('data-new-id', imageId);
                        card.innerHTML = `
                            <input type="hidden" name="ImagesOrder" value="new" data-order-input />
                            <img src="${previewUrl}" alt="Image" class="image-preview" />
                            <div class="image-controls">
                                <button type="button" class="image-control-btn image-drag-handle" data-drag-handle aria-label="Drag to reorder" title="Drag to reorder">
                                    <i class="fa fa-bars" aria-hidden="true"></i>
                                </button>
                                <div class="image-move-controls">
                                    <button type="button" class="image-control-btn" data-move="left" aria-label="Move image left" title="Move left">
                                        <i class="fa fa-chevron-left" aria-hidden="true"></i>
                                    </button>
                                    <button type="button" class="image-control-btn" data-move="right" aria-label="Move image right" title="Move right">
                                        <i class="fa fa-chevron-right" aria-hidden="true"></i>
                                    </button>
                                </div>
                                <button type="button" class="image-control-btn image-remove-btn" data-remove-image aria-label="Remove image" title="Remove">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>`;
                        list.prepend(card);
                    }

                    if (droppedCount > 0) {
                        setLimitMessage(`Maximum ${maxImages} images per plugin. ${droppedCount} file(s) were ignored.`);
                    } else {
                        setLimitMessage('');
                    }

                    input.value = '';
                    rebuildInputFileList();
                    refreshMoveButtonsState();
                });
            }

            if (!list)
                return;

            const rebuildInputFileList = () => {
                if (!input)
                    return;

                const dataTransfer = new DataTransfer();
                Array.from(list.querySelectorAll('[data-image-item][data-new-id]')).forEach(entry => {
                    const id = entry.getAttribute('data-new-id');
                    const image = id ? newImages.get(id) : null;
                    if (image)
                        dataTransfer.items.add(image.file);
                });
                input.files = dataTransfer.files;
            };

            const refreshMoveButtonsState = () => {
                const items = Array.from(list.querySelectorAll('[data-image-item]'));
                items.forEach((item, index) => {
                    const leftBtn = item.querySelector('button[data-move="left"]');
                    const rightBtn = item.querySelector('button[data-move="right"]');
                    if (leftBtn)
                        leftBtn.disabled = index === 0;
                    if (rightBtn)
                        rightBtn.disabled = index === items.length - 1;
                });
            };

            let draggedItem = null;

            list.addEventListener('mousedown', evt => {
                const handle = evt.target.closest('[data-drag-handle]');
                if (!handle)
                    return;

                const item = handle.closest('[data-image-item]');
                if (!item)
                    return;

                item.setAttribute('draggable', 'true');
            });

            list.addEventListener('mouseup', () => {
                Array.from(list.querySelectorAll('[data-image-item]')).forEach(item => item.setAttribute('draggable', 'false'));
            });

            list.addEventListener('dragstart', evt => {
                const item = evt.target.closest('[data-image-item]');
                if (!item || item.getAttribute('draggable') !== 'true') {
                    evt.preventDefault();
                    return;
                }

                draggedItem = item;
                item.classList.add('is-dragging');
                if (evt.dataTransfer) {
                    evt.dataTransfer.effectAllowed = 'move';
                    evt.dataTransfer.setData('text/plain', 'image');
                }
            });

            list.addEventListener('dragover', evt => {
                if (!draggedItem)
                    return;

                evt.preventDefault();
                const listRect = list.getBoundingClientRect();
                const edgeThreshold = 56;
                const scrollStep = 6;
                if (evt.clientX < listRect.left + edgeThreshold)
                    list.scrollLeft -= scrollStep;
                else if (evt.clientX > listRect.right - edgeThreshold)
                    list.scrollLeft += scrollStep;

                const target = evt.target.closest('[data-image-item]');
                if (!target || target === draggedItem)
                    return;

                const rect = target.getBoundingClientRect();
                const placeBefore = evt.clientX < rect.left + (rect.width / 2);
                list.insertBefore(draggedItem, placeBefore ? target : target.nextElementSibling);
            });

            list.addEventListener('dragend', () => {
                if (draggedItem) {
                    draggedItem.classList.remove('is-dragging');
                    draggedItem = null;
                }

                Array.from(list.querySelectorAll('[data-image-item]')).forEach(item => item.setAttribute('draggable', 'false'));
                rebuildInputFileList();
                refreshMoveButtonsState();
            });

            list.addEventListener('click', (evt) => {
                const target = evt.target.closest('button');
                if (!target)
                    return;

                if (target.disabled) return;
                if (target.hasAttribute('data-drag-handle'))
                    return;

                const item = target.closest('[data-image-item]');
                if (!item)
                    return;

                if (target.hasAttribute('data-remove-image')) {
                    const imageId = item.getAttribute('data-new-id');
                    if (imageId && newImages.has(imageId)) {
                        URL.revokeObjectURL(newImages.get(imageId).previewUrl);
                        newImages.delete(imageId);
                    }
                    item.remove();

                    rebuildInputFileList();

                    setLimitMessage('');
                    refreshMoveButtonsState();
                    return;
                }

                const move = target.getAttribute('data-move');
                if (move === 'left') {
                    const prev = item.previousElementSibling;
                    if (prev)
                        list.insertBefore(item, prev);
                }
                else if (move === 'right') {
                    const next = item.nextElementSibling;
                    if (next)
                        list.insertBefore(next, item);
                }

                item.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });

                rebuildInputFileList();

                refreshMoveButtonsState();
            });

            refreshMoveButtonsState();

            const existingCount = list.querySelectorAll('[data-image-item]').length;
            if (existingCount >= maxImages)
                setLimitMessage(`Maximum ${maxImages} images per plugin.`);
        })();
    </script>
}
