@model PluginBuilder.ViewModels.Plugin.CreatePluginViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Create a new plugin";
}

<h2 class="mt-1 mb-4">@ViewData["Title"]</h2>
<div class="row">
    <div class="col-xl-8 col-xxl-constrain">
        <form asp-action="CreatePlugin" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="PluginSlug" class="form-label" data-required></label>
                <input asp-for="PluginSlug" class="form-control" placeholder="my-awesome-plugin" required />
                <span asp-validation-for="PluginSlug" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PluginTitle" class="form-label" data-required></label>
                <input asp-for="PluginTitle" class="form-control" required />
                <span asp-validation-for="PluginTitle" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="form-label" data-required></label>
                <textarea asp-for="Description" class="form-control" rows="5" placeholder="Plugin description..." required></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Logo" class="form-label"></label>
                <input asp-for="Logo" type="file" class="form-control flex-grow" accept="image/*">
                <span asp-validation-for="Logo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Screenshots" class="form-label"></label>
                <input asp-for="Screenshots" id="create-screenshots-input" type="file" class="form-control" accept="image/*" multiple>
                <span asp-validation-for="Screenshots" class="text-danger"></span>
                <div id="create-screenshots-limit-error" class="text-danger small mt-1 d-none"></div>
                <div id="create-screenshots-list" class="d-flex gap-3 mt-2 screenshots-order-list d-none"></div>
            </div>
            <div class="form-group">
                <label asp-for="VideoUrl" class="form-label"></label>
                <input asp-for="VideoUrl" type="url" class="form-control" />
                <span asp-validation-for="VideoUrl" class="text-danger"></span>
            </div>
            <div class="form-group mt-4">
                <input type="submit" value="Create" class="btn btn-primary" id="Create" />
            </div>
        </form>
    </div>
</div>

@section FooterScripts {
    <script>
        (() => {
            const input = document.getElementById('create-screenshots-input');
            const list = document.getElementById('create-screenshots-list');
            const limitError = document.getElementById('create-screenshots-limit-error');
            const form = input?.closest('form');
            if (!input || !list || !form)
                return;

            const maxScreenshots = 10;
            const selectedScreenshots = [];
            let nextScreenshotId = 0;

            const setLimitMessage = (message) => {
                if (!limitError)
                    return;

                if (message) {
                    limitError.textContent = message;
                    limitError.classList.remove('d-none');
                }
                else {
                    limitError.textContent = '';
                    limitError.classList.add('d-none');
                }
            };

            const buildFileList = () => {
                const dataTransfer = new DataTransfer();
                selectedScreenshots.forEach(item => dataTransfer.items.add(item.file));
                input.files = dataTransfer.files;
            };

            const refreshMoveButtonsState = () => {
                const items = Array.from(list.querySelectorAll('[data-screenshot-item]'));
                items.forEach((item, index) => {
                    const leftBtn = item.querySelector('button[data-move="left"]');
                    const rightBtn = item.querySelector('button[data-move="right"]');
                    if (leftBtn)
                        leftBtn.disabled = index === 0;
                    if (rightBtn)
                        rightBtn.disabled = index === items.length - 1;
                });
            };

            const render = () => {
                list.innerHTML = '';

                if (selectedScreenshots.length === 0) {
                    list.classList.add('d-none');
                    buildFileList();
                    setLimitMessage('');
                    return;
                }

                list.classList.remove('d-none');

                selectedScreenshots.forEach((item, index) => {
                    const card = document.createElement('div');
                    card.className = 'screenshot-item border rounded';
                    card.setAttribute('data-screenshot-item', 'true');
                    card.setAttribute('data-id', String(item.id));

                    card.innerHTML = `
                        <img src="${item.previewUrl}" alt="Screenshot preview" class="screenshot-preview" />
                        <div class="screenshot-controls">
                            <button type="button" class="screenshot-control-btn screenshot-drag-handle" data-drag-handle aria-label="Drag to reorder" title="Drag to reorder">
                                <i class="fa fa-bars" aria-hidden="true"></i>
                            </button>
                            <div class="screenshot-move-controls">
                                <button type="button" class="screenshot-control-btn" data-move="left" aria-label="Move screenshot left" title="Move left">
                                    <i class="fa fa-chevron-left" aria-hidden="true"></i>
                                </button>
                                <button type="button" class="screenshot-control-btn" data-move="right" aria-label="Move screenshot right" title="Move right">
                                    <i class="fa fa-chevron-right" aria-hidden="true"></i>
                                </button>
                            </div>
                            <button type="button" class="screenshot-control-btn screenshot-remove-btn" data-remove-screenshot aria-label="Remove screenshot" title="Remove">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>`;

                    list.appendChild(card);
                });

                refreshMoveButtonsState();
                buildFileList();

                if (selectedScreenshots.length >= maxScreenshots)
                    setLimitMessage(`Maximum ${maxScreenshots} screenshots per plugin.`);
                else
                    setLimitMessage('');
            };

            input.addEventListener('change', () => {
                const files = Array.from(input.files || []);
                const availableSlots = maxScreenshots - selectedScreenshots.length;

                if (availableSlots <= 0) {
                    setLimitMessage(`Maximum ${maxScreenshots} screenshots per plugin.`);
                    input.value = '';
                    return;
                }

                const acceptedFiles = files.slice(0, availableSlots);
                const droppedCount = files.length - acceptedFiles.length;

                const newScreenshots = acceptedFiles.map(file => ({
                    id: nextScreenshotId++,
                    file,
                    previewUrl: URL.createObjectURL(file)
                }));
                selectedScreenshots.unshift(...newScreenshots);

                if (droppedCount > 0)
                    setLimitMessage(`Maximum ${maxScreenshots} screenshots per plugin. ${droppedCount} file(s) were ignored.`);

                input.value = '';
                render();
            });

            list.addEventListener('click', evt => {
                const target = evt.target.closest('button');
                if (!target)
                    return;
                if (target.hasAttribute('data-drag-handle'))
                    return;

                const item = target.closest('[data-screenshot-item]');
                if (!item)
                    return;

                const id = Number(item.getAttribute('data-id'));
                const index = selectedScreenshots.findIndex(x => x.id === id);
                if (Number.isNaN(index) || index < 0 || index >= selectedScreenshots.length)
                    return;

                if (target.hasAttribute('data-remove-screenshot')) {
                    URL.revokeObjectURL(selectedScreenshots[index].previewUrl);
                    selectedScreenshots.splice(index, 1);
                    render();
                    return;
                }

                const move = target.getAttribute('data-move');
                if (move === 'left' && index > 0) {
                    [selectedScreenshots[index - 1], selectedScreenshots[index]] = [selectedScreenshots[index], selectedScreenshots[index - 1]];
                }
                else if (move === 'right' && index < selectedScreenshots.length - 1) {
                    [selectedScreenshots[index], selectedScreenshots[index + 1]] = [selectedScreenshots[index + 1], selectedScreenshots[index]];
                }

                render();
            });

            let draggedItem = null;

            list.addEventListener('mousedown', evt => {
                const handle = evt.target.closest('[data-drag-handle]');
                if (!handle)
                    return;

                const item = handle.closest('[data-screenshot-item]');
                if (!item)
                    return;

                item.setAttribute('draggable', 'true');
            });

            list.addEventListener('mouseup', () => {
                Array.from(list.querySelectorAll('[data-screenshot-item]')).forEach(item => item.setAttribute('draggable', 'false'));
            });

            list.addEventListener('dragstart', evt => {
                const item = evt.target.closest('[data-screenshot-item]');
                if (!item || item.getAttribute('draggable') !== 'true') {
                    evt.preventDefault();
                    return;
                }

                draggedItem = item;
                item.classList.add('is-dragging');
                if (evt.dataTransfer) {
                    evt.dataTransfer.effectAllowed = 'move';
                    evt.dataTransfer.setData('text/plain', 'screenshot');
                }
            });

            list.addEventListener('dragover', evt => {
                if (!draggedItem)
                    return;

                evt.preventDefault();
                const listRect = list.getBoundingClientRect();
                const edgeThreshold = 56;
                const scrollStep = 6;
                if (evt.clientX < listRect.left + edgeThreshold)
                    list.scrollLeft -= scrollStep;
                else if (evt.clientX > listRect.right - edgeThreshold)
                    list.scrollLeft += scrollStep;

                const target = evt.target.closest('[data-screenshot-item]');
                if (!target || target === draggedItem)
                    return;

                const rect = target.getBoundingClientRect();
                const placeBefore = evt.clientX < rect.left + (rect.width / 2);
                list.insertBefore(draggedItem, placeBefore ? target : target.nextElementSibling);
            });

            list.addEventListener('dragend', () => {
                if (draggedItem) {
                    draggedItem.classList.remove('is-dragging');
                    draggedItem = null;
                }

                Array.from(list.querySelectorAll('[data-screenshot-item]')).forEach(item => item.setAttribute('draggable', 'false'));

                const orderedIds = Array.from(list.querySelectorAll('[data-screenshot-item]'))
                    .map(item => Number(item.getAttribute('data-id')))
                    .filter(id => !Number.isNaN(id));
                const orderMap = new Map(orderedIds.map((id, idx) => [id, idx]));
                selectedScreenshots.sort((a, b) => (orderMap.get(a.id) ?? 0) - (orderMap.get(b.id) ?? 0));
                render();
            });

            form.addEventListener('submit', () => {
                buildFileList();
            });

            window.addEventListener('beforeunload', () => {
                selectedScreenshots.forEach(item => URL.revokeObjectURL(item.previewUrl));
            });
        })();
    </script>
}
