@model PluginBuilder.ViewModels.Plugin.CreatePluginViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Create a new plugin";
}

<h2 class="mt-1 mb-4">@ViewData["Title"]</h2>
<div class="row">
    <div class="col-xl-8 col-xxl-constrain">
        <form asp-action="CreatePlugin" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="PluginSlug" class="form-label" data-required></label>
                <input asp-for="PluginSlug" class="form-control" placeholder="my-awesome-plugin" required />
                <span asp-validation-for="PluginSlug" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PluginTitle" class="form-label" data-required></label>
                <input asp-for="PluginTitle" class="form-control" required />
                <span asp-validation-for="PluginTitle" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="form-label" data-required></label>
                <textarea asp-for="Description" class="form-control" rows="5" placeholder="Plugin description..." required></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Logo" class="form-label"></label>
                <input asp-for="Logo" type="file" class="form-control flex-grow" accept="image/*">
                <span asp-validation-for="Logo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Images" class="form-label"></label>
                <input asp-for="Images" id="create-images-input" type="file" class="form-control" accept="image/*" multiple>
                <span asp-validation-for="Images" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="VideoUrl" class="form-label"></label>
                <input asp-for="VideoUrl" type="url" class="form-control" />
                <span asp-validation-for="VideoUrl" class="text-danger"></span>
            </div>
            <div class="form-group mt-4">
                <input type="submit" value="Create" class="btn btn-primary" id="Create" />
            </div>
        </form>
    </div>
</div>


@section FooterScripts {
	<script>
		document.getElementById('create-images-input').addEventListener('change', function () {
			const maxTotal = 10 * 1024 * 1024;
			const errorSpan = document.querySelector('span[data-valmsg-for="Images"]');
			const totalSize = Array.from(this.files).reduce((sum, file) => sum + file.size, 0);

			if (totalSize > maxTotal) {
				errorSpan.textContent = 'Total size of images cannot exceed 10MB.';
				errorSpan.classList.add('text-danger');
				this.value = '';
				return;
			}

			if (errorSpan.classList.contains('field-validation-valid'))
				errorSpan.textContent = '';
		});
	</script>
}
